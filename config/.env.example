NODE_ENV=production

APP_PORT=42180
AI_PORT=42181
HERMES_PORT=42182

# Resource search provider. Use hybrid to query XiaoYa/OpenList/Emby together.
SEARCH_PROVIDER=hybrid

# XiaoYa AList settings
XIAOYA_BASE_URL=http://192.168.1.35:5678
XIAOYA_SOURCE_NAME=XiaoYaAList
XIAOYA_SEARCH_TYPE=video
XIAOYA_MAX_RESULTS=300
XIAOYA_AUTH_MODE=none
XIAOYA_USERNAME=
XIAOYA_PASSWORD=
XIAOYA_PATH_PASSWORD=
XIAOYA_LOOKUP_FILE_SIZE=true
XIAOYA_SIZE_LOOKUP_CONCURRENCY=6
XIAOYA_SIZE_LOOKUP_TIMEOUT_MS=5000
XIAOYA_DOWNLOAD_LINK_TIMEOUT_MS=30000
# Expand directory search hits so TV/anime folders can offer full-season and single-episode choices.
XIAOYA_FOLDER_EXPANSION_MAX_FOLDERS=20
XIAOYA_FOLDER_SCAN_MAX_DEPTH=4
XIAOYA_FOLDER_SCAN_MAX_ITEMS=1200

# Optional Emby source. Use EMBY_PROXY_URL when the app host must access Emby through a proxy.
EMBY_BASE_URL=
EMBY_SOURCE_NAME=Emby
EMBY_SERVER_ID=
EMBY_USERNAME=
EMBY_PASSWORD=
EMBY_ENABLED=true
EMBY_PROXY_URL=
EMBY_ARIA2_PROXY_URL=
EMBY_HTTP_CLIENT=undici
EMBY_CLIENT_NAME=MediaBrain
EMBY_DEVICE_NAME=Codex
EMBY_DEVICE_ID=mediabrain-codex
EMBY_CLIENT_VERSION=0.1.0
EMBY_AUTH_QUOTE_STYLE=quoted
EMBY_REQUEST_TIMEOUT_MS=30000
EMBY_MAX_RESULTS=80
EMBY_MAX_SERIES_EXPANSIONS=4
EMBY_MAX_EPISODES_PER_SERIES=300
EMBY_SERVER_REGISTRY_PATH=./data/emby-servers.json

# Optional OpenList settings. Leave empty if XiaoYa is the only search source.
OPENLIST_BASE_URL=
OPENLIST_TOKEN=
OPENLIST_AUTH_MODE=auto
OPENLIST_USERNAME=
OPENLIST_PASSWORD=
OPENLIST_SEARCH_PARENT=/
OPENLIST_SOURCE_NAME=OpenList
OPENLIST_PAGE_SIZE=100
OPENLIST_SCAN_MAX_DEPTH=4
OPENLIST_SCAN_MAX_ITEMS=5000
OPENLIST_PATH_PASSWORD=
OPENLIST_TRANSFER_TARGET_ROOT=/MediaBrain/Transfers

# Internal service endpoints used inside docker compose.
AI_SERVICE_URL=http://ai:42181
HERMES_EXECUTOR_URL=http://hermes:42182
AI_TARGET_ROOT=/media/organized
HERMES_RENAME_MODE=filesystem

# Existing NAS Aria2 JSON-RPC.
ARIA2_RPC_URL=http://192.168.1.35:46800/jsonrpc
ARIA2_RPC_SECRET=change-me
ARIA2_DOWNLOAD_DIR=/downloads
ARIA2_RPC_TIMEOUT_MS=15000
ARIA2_POLL_INTERVAL_MS=2000
ARIA2_STATUS_POLL_RETRY_ATTEMPTS=3
ARIA2_STATUS_POLL_RETRY_DELAY_MS=1000
# No-progress timeout. Downloads may run longer as long as Aria2 keeps making progress. Set 0 to disable.
ARIA2_DOWNLOAD_TIMEOUT_MS=1800000

# Only used if you also deploy Aria2 from this project's optional compose snippet.
RPC_SECRET=change-me

# Optional local fallback for development without OpenList/XiaoYa.
OPENLIST_MOCK_ROOT=
TRANSFER_TARGET_ROOT=./transferred
